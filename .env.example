SECRET_KEY=change-this-super-secret-key-in-production
ANTHROPIC_API_KEY=sk-ant-...

# Correo: preferir Resend (si RESEND_API_KEY está definido, se usa Resend y no SMTP)
RESEND_API_KEY=re_xxxxxxxx
# Remitente verificado en el panel de Resend (dominio propio o onboarding@resend.dev para pruebas)
RESEND_FROM_EMAIL=RevoTake <onboarding@resend.dev>

# Alternativa sin Resend:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-app-password

FRONTEND_URL=https://revotake.vercel.app
ALLOWED_ORIGINS=["http://localhost:3000","https://revotake.vercel.app"]

# Google Maps (frontend)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key_here
